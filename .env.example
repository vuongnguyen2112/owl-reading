DATABASE_URL="postgresql://postgres:postgres@localhost:5432/owl_reading?schema=public"
NODE_ENV="development"
PORT=3000
CORS_ORIGINS="http://localhost:4200,http://localhost:4201"

JWT_ACCESS_SECRET="development-access-secret"
JWT_REFRESH_SECRET="development-refresh-secret"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
AUTH_LOGIN_RATE_LIMIT_TTL_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_REGISTER_RATE_LIMIT_TTL_SECONDS=60
AUTH_REGISTER_RATE_LIMIT_MAX=3
AUTH_REFRESH_RATE_LIMIT_TTL_SECONDS=60
AUTH_REFRESH_RATE_LIMIT_MAX=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE="lax"
