DATABASE_URL="postgresql://postgres:postgres@localhost:5432/owl_reading?schema=public"
NODE_ENV="development"
PORT=3000
CORS_ORIGINS="http://localhost:4200,http://localhost:4201"

# Development-only placeholder until real admin authentication is implemented.
ADMIN_API_KEY="local-development-admin-key"
ALLOW_PLACEHOLDER_ADMIN=false

JWT_ACCESS_SECRET="development-access-secret"
JWT_REFRESH_SECRET="development-refresh-secret"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE="lax"
